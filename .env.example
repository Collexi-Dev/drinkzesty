# Brand toolkit basic auth: username:password (URL-safe, no quotes).
# When unset in production, /brand/* returns 503 instead of leaking content.
# Set in Vercel: Settings → Environment Variables → BRAND_AUTH (Production + Preview).
BRAND_AUTH="zesty:change-me-please"

# Meta Pixel ID. Public (exposed to the client). When unset, the pixel doesn't load.
NEXT_PUBLIC_META_PIXEL_ID=""
